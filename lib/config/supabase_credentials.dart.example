/// Copiez ce fichier en `supabase_credentials.dart` (même dossier) et
/// remplissez-le avec vos vraies clés depuis https://app.supabase.com
/// (Settings > API). Le fichier `supabase_credentials.dart` est ignoré par
/// Git : vos clés ne seront jamais commitées.
class SupabaseCredentials {
  static const String supabaseUrl = 'https://YOUR_PROJECT_ID.supabase.co';
  static const String supabaseAnonKey = 'YOUR_ANON_KEY';
}
